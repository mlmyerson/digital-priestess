# Digital Priestess local configuration

APP_HOST=127.0.0.1
APP_PORT=8787

# LM Studio local server. The model name should match the local model loaded in LM Studio.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_TIMEOUT_SECONDS=60

# Approved local archive root. Keep this outside the repository when it contains private data.
ARCHIVE_ROOT=
DATA_DIR=.local/data

# OCR is reserved for the next ingestion layer and must remain local when enabled.
ENABLE_OCR=false

# Comma-separated local frontend origins.
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173